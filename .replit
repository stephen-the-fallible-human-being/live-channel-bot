modules = ["python-3.11"]

[packager]
language = "python3"

[packager.features]
guessImports = false
ignoredPackages = ["discord.py"]

[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Run"

[[workflows.workflow]]
name = "Run"
author = 45995006
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"
