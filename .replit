modules = ["python-3.11"]
# Define the language for the Replit App

[packager]
language = "python3"
ignoredPackages = ["discord.py"]

[packager.features]
guessImports = false

[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Run"

[[workflows.workflow]]
name = "Run"
author = 45995006
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 main.py"
